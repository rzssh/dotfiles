diff --git a/src/test_config.c b/src/test_config.c
new file mode 100644
index 0000000..b5e1f2d
--- /dev/null
+++ b/src/test_config.c
@@ -0,0 +1,53 @@
+#include "src/config.h"
+#include "src/log.h"
+
+int main() {
+    struct config config;
+    config_set_default(&config);
+
+    if (config.general.click_count != 1) {
+        LOG_ERR(
+            "Expected default click count 1, got %d.",
+            config.general.click_count
+        );
+        return 1;
+    }
+
+    struct config_loader loader;
+    config_loader_init(&loader, &config);
+
+    char double_click[] = "click_count=2";
+    if (config_loader_load_cli_param(&loader, double_click) ||
+        config.general.click_count != 2) {
+        LOG_ERR("Could not set double click.");
+        return 2;
+    }
+
+    char triple_click[] = "click_count=3";
+    if (config_loader_load_cli_param(&loader, triple_click) ||
+        config.general.click_count != 3) {
+        LOG_ERR("Could not set triple click.");
+        return 3;
+    }
+
+    char zero_click[] = "click_count=0";
+    if (!config_loader_load_cli_param(&loader, zero_click)) {
+        LOG_ERR("Accepted zero click count.");
+        return 4;
+    }
+
+    char excessive_click[] = "click_count=4";
+    if (!config_loader_load_cli_param(&loader, excessive_click)) {
+        LOG_ERR("Accepted excessive click count.");
+        return 5;
+    }
+
+    char invalid_click[] = "click_count=no";
+    if (!config_loader_load_cli_param(&loader, invalid_click)) {
+        LOG_ERR("Accepted invalid click count.");
+        return 6;
+    }
+
+    config_free_values(&config);
+    return 0;
+}
