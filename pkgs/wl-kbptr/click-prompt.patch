+
+    cairo_set_operator(cairo, CAIRO_OPERATOR_SOURCE);
+    cairo_set_source_u32(cairo, config->unselectable_bg_color);
+    cairo_paint(cairo);
+
+    double pointer_x = ms->area.x + ms->area.w / 2.;
+    double pointer_y = ms->area.y + ms->area.h / 2.;
+    double pointer_r = config->pointer_size / 2.;
+    cairo_set_source_u32(cairo, config->pointer_color);
+    cairo_set_line_width(cairo, 2);
+    cairo_move_to(cairo, pointer_x - pointer_r, pointer_y);
+    cairo_line_to(cairo, pointer_x + pointer_r, pointer_y);
+    cairo_move_to(cairo, pointer_x, pointer_y - pointer_r);
+    cairo_line_to(cairo, pointer_x, pointer_y + pointer_r);
+    cairo_stroke(cairo);
+
+    char label[256];
+    snprintf(
+        label, sizeof(label),
+        "%s click   %s right   %s middle   Enter move   Backspace back   Esc cancel",
+        state->home_row[HOME_ROW_LEFT_CLICK],
