+    cairo_set_font_size(cairo, config->label_font_size);
+    cairo_text_extents_t te;
+    cairo_text_extents(cairo, label, &te);
+
+    double padding = config->label_padding;
+    double width   = te.width + padding * 2;
+    double height  = te.height + padding * 2;
+    double x       = (state->surface_width - width) / 2.;
+    double y       = padding;
+
+    cairo_set_operator(cairo, CAIRO_OPERATOR_OVER);
+    cairo_set_source_u32(cairo, config->even_area_bg_color);
+    cairo_rectangle(cairo, x, y, width, height);
+    cairo_fill_preserve(cairo);
+    cairo_set_source_u32(cairo, config->pointer_color);
+    cairo_set_line_width(cairo, 1);
+    cairo_stroke(cairo);
+
+    cairo_set_source_u32(cairo, config->label_color);
+    cairo_move_to(
+        cairo, x + padding - te.x_bearing, y + padding - te.y_bearing
