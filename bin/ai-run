#!/usr/bin/env python3
import ast
import os
import re
import stat
import sys
from pathlib import Path


PROFILE_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]*$")
KEY_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")
SAFE_KEYS = {
    "COLORTERM",
    "DBUS_SESSION_BUS_ADDRESS",
    "DISPLAY",
    "EDITOR",
    "HOME",
    "LANG",
    "LOGNAME",
    "PAGER",
    "PATH",
    "SHELL",
    "SSL_CERT_DIR",
    "SSL_CERT_FILE",
    "TERM",
    "TERMINFO",
    "TERMINFO_DIRS",
    "TERM_PROGRAM",
    "TMPDIR",
    "USER",
    "VISUAL",
    "WAYLAND_DISPLAY",
    "XAUTHORITY",
    "XDG_CACHE_HOME",
    "XDG_CONFIG_HOME",
    "XDG_CURRENT_DESKTOP",
    "XDG_DATA_DIRS",
    "XDG_DATA_HOME",
    "XDG_RUNTIME_DIR",
    "XDG_SESSION_DESKTOP",
    "XDG_SESSION_TYPE",
    "XDG_STATE_HOME",
}
SAFE_PREFIXES = ("HERDR_", "LC_", "NIX_")
RESERVED_KEYS = SAFE_KEYS | {
    "AI_DEFAULT_PROFILE",
    "AI_PROFILE",
    "AI_PROFILES_DIR",
    "CLAUDE_CONFIG_DIR",
    "CODEX_HOME",
    "GH_CONFIG_DIR",
    "GIT_CONFIG_GLOBAL",
    "OPENCODE_CONFIG_DIR",
    "PI_CODING_AGENT_DIR",
}


def fail(message):
    print(f"ai-run: {message}", file=sys.stderr)
    raise SystemExit(2)


def arguments():
    args = sys.argv[1:]
    if args in (["-h"], ["--help"]):
        print("usage: ai-run [profile] -- command [args...]")
        raise SystemExit(0)
    if "--" not in args:
        fail("usage: ai-run [profile] -- command [args...]")
    split = args.index("--")
    if split > 1 or not args[split + 1 :]:
        fail("usage: ai-run [profile] -- command [args...]")
    profile = args[0] if split else os.environ.get("AI_PROFILE") or os.environ.get(
        "AI_DEFAULT_PROFILE", "personal"
    )
    if not PROFILE_RE.fullmatch(profile):
        fail(f"invalid profile: {profile}")
    return profile, args[split + 1 :]


def value(raw, line):
    raw = raw.strip()
    if not raw:
        return ""
    if raw[0] in "\"'":
        try:
            parsed = ast.literal_eval(raw)
        except (SyntaxError, ValueError):
            fail(f"invalid quoted value on line {line}")
        if not isinstance(parsed, str):
            fail(f"non-string value on line {line}")
        return parsed
    return raw


def load(path):
    try:
        info = path.stat()
    except FileNotFoundError:
        fail(f"profile file not found: {path}")
    if not stat.S_ISREG(info.st_mode):
        fail(f"profile path is not a regular file: {path}")
    if info.st_uid != os.getuid():
        fail(f"profile file is not owned by current user: {path}")
    if info.st_mode & 0o077:
        fail(f"profile file must be private (0600 or stricter): {path}")
    result = {}
    for number, raw in enumerate(path.read_text().splitlines(), 1):
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        line = line.removeprefix("export ").lstrip()
        if "=" not in line:
            fail(f"invalid assignment on line {number}")
        key, raw_value = line.split("=", 1)
        key = key.strip()
        if not KEY_RE.fullmatch(key):
            fail(f"invalid key on line {number}: {key}")
        if key in RESERVED_KEYS or key.startswith(SAFE_PREFIXES):
            fail(f"profile cannot override runtime key: {key}")
        result[key] = value(raw_value, number)
    return result


def check_directory(path):
    try:
        info = path.stat()
    except FileNotFoundError:
        fail(f"profile directory not found: {path}")
    if not stat.S_ISDIR(info.st_mode):
        fail(f"profile path is not a directory: {path}")
    if info.st_uid != os.getuid():
        fail(f"profile directory is not owned by current user: {path}")
    if info.st_mode & 0o077:
        fail(f"profile directory must be private (0700 or stricter): {path}")


def paths(profile, directory, home):
    if profile == "personal":
        return {
            "CLAUDE_CONFIG_DIR": home / ".claude",
            "CODEX_HOME": home / ".codex",
            "GH_CONFIG_DIR": home / ".config" / "gh",
            "GIT_CONFIG_GLOBAL": home / ".gitconfig",
            "PI_CODING_AGENT_DIR": home / ".pi" / "agent",
        }
    return {
        "CLAUDE_CONFIG_DIR": directory / "claude",
        "CODEX_HOME": directory / "codex",
        "GH_CONFIG_DIR": directory / "gh",
        "GIT_CONFIG_GLOBAL": directory / "gitconfig",
        "OPENCODE_CONFIG_DIR": directory / "opencode",
        "PI_CODING_AGENT_DIR": directory / "pi",
        "XDG_CACHE_HOME": directory / "xdg-cache",
        "XDG_DATA_HOME": directory / "xdg-data",
        "XDG_STATE_HOME": directory / "xdg-state",
    }


def link_shared_pi(home, directory):
    source = home / ".pi" / "agent"
    if directory == source:
        return
    for relative in ("AGENTS.md", "settings.json", "extensions/herdr-agent-state.ts"):
        target = directory / relative
        shared = source / relative
        if not target.exists() and not target.is_symlink() and shared.exists():
            target.symlink_to(shared)


def main():
    profile, command = arguments()
    home = Path(os.environ.get("HOME", "~")).expanduser()
    data = Path(os.environ.get("XDG_DATA_HOME", home / ".local" / "share"))
    root = Path(os.environ.get("AI_PROFILES_DIR", data / "ai" / "profiles")).expanduser()
    directory = root / profile
    check_directory(directory)
    profile_env = load(directory / "env")
    environment = {
        key: val
        for key, val in os.environ.items()
        if key in SAFE_KEYS or key.startswith(SAFE_PREFIXES)
    }
    environment.update(profile_env)
    environment["AI_PROFILE"] = profile
    runtime_paths = paths(profile, directory, home)
    for key, path in runtime_paths.items():
        environment[key] = str(path)
        if key != "GIT_CONFIG_GLOBAL":
            path.mkdir(mode=0o700, parents=True, exist_ok=True)
        if key == "PI_CODING_AGENT_DIR":
            (path / "extensions").mkdir(mode=0o700, exist_ok=True)
    link_shared_pi(home, runtime_paths["PI_CODING_AGENT_DIR"])
    os.execvpe(command[0], command, environment)


if __name__ == "__main__":
    main()
