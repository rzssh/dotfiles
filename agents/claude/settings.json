{
  "effortLevel": "high",
  "enabledPlugins": {
    "caveman@caveman": true,
    "ponytail@ponytail": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "repo": "JuliusBrussee/caveman",
        "source": "github"
      }
    },
    "ponytail": {
      "source": {
        "repo": "DietrichGebert/ponytail",
        "source": "github"
      }
    }
  },
  "permissions": {
    "deny": [
      "Read(~/.local/share/ai/profiles/**)",
      "Read(~/.config/sops/**)",
      "Read(~/.codex/auth.json)",
      "Read(~/.claude/.credentials.json)",
      "Read(~/.pi/agent/auth.json)",
      "Read(~/.hermes/auth.json)",
      "Read(~/.local/share/opencode/auth.json)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.git-credentials)",
      "Read(~/.netrc)"
    ]
  },
  "sandbox": {
    "allowUnsandboxedCommands": false,
    "enabled": true,
    "filesystem": {
      "denyRead": [
        "~/.local/share/ai/profiles",
        "~/.config/sops",
        "~/.codex/auth.json",
        "~/.claude/.credentials.json",
        "~/.pi/agent/auth.json",
        "~/.hermes/auth.json",
        "~/.local/share/opencode/auth.json",
        "~/.config/gh/hosts.yml",
        "~/.git-credentials",
        "~/.netrc"
      ]
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "tui": "fullscreen"
}
